---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Denis Tomilin — AI Architect">
    <main class="max-w-[960px] mx-auto px-6 pt-8 sm:pt-14">

      <!-- Hero -->
      <section class="flex flex-col md:flex-row gap-10 md:gap-16 mb-16">

        <!-- Left: Identity -->
        <div class="md:w-1/2">
          <div class="flex items-center gap-5 mb-6">
            <img
              src="/photo.jpg"
              alt="Denis Tomilin"
              class="w-24 h-24 rounded-full object-cover ring-2 ring-iris/20 shadow-lg shrink-0"
            />
            <div>
              <h1 class="text-2xl font-bold leading-tight text-stone-900">Denis Tomilin</h1>
              <p class="text-sm text-stone-500 mt-1">AI Architect · Consultant · Researcher</p>
            </div>
          </div>

          <p class="text-xl font-semibold leading-snug text-stone-900 mb-5">
            I architect Agentic AI systems and help enterprises <span class="text-iris">actually ship them</span>.
          </p>

          <p class="text-[15px] text-stone-500 leading-relaxed mb-4">
            One of the leading experts at <a href="https://dataart.com" class="text-iris hover:text-iris-hover font-medium transition-colors" target="_blank" rel="noopener">DataArt</a>'s AI Lab — designing and shipping multi-agent systems to production.
          </p>

          <!-- Tech stack inline -->
          <p class="text-[12px] font-mono text-stone-500 mb-8">LangGraph · Agno · OpenClaw · MCP · mem0 · Claude Code</p>

          <!-- Career arc + personal -->
          <div class="border-l-2 border-stone-200 pl-4 mb-8">
            <p class="text-[14px] text-stone-600 font-mono">
              <span class="text-stone-800 font-semibold">18+ years:</span> C/C++ game dev → Python lead → Architect → CTO → AI Architect <span class="text-stone-500">· 4+ years with AI</span>
            </p>
            <p class="text-[13px] text-stone-500 mt-1.5">Guitarist · ethical hacker background · traveler</p>
          </div>

          <div class="flex items-center gap-4">
            <a href="https://linkedin.com/in/denistomilin-28866686" class="transition-opacity hover:opacity-70" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://github.com/iorlas" class="transition-opacity hover:opacity-70" target="_blank" rel="noopener" aria-label="GitHub">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="#181717"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            </a>
            <a href="https://x.com/iorlasd" class="transition-opacity hover:opacity-70" target="_blank" rel="noopener" aria-label="X">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#000000"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://forms.gle/otSXYCxvH2au6ngm9" class="transition-opacity hover:opacity-70" target="_blank" rel="noopener" aria-label="Contact">
              <Icon name="mail" size={20} class="text-iris" />
            </a>
          </div>
        </div>

        <!-- Right: Credentials -->
        <div class="md:w-1/2 md:pt-2">
          <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-3">Credentials</h2>

          <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 text-[13px] font-medium text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap">
              <Icon name="building" size={13} class="text-stone-500" />
              DataArt · since 2017
            </span>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-medium text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap">
              <Icon name="zap" size={13} class="text-stone-500" />
              Ex-CTO, Grand Capital
            </span>
            <a href="https://stripecertifications.credential.net/026ed691-e891-4a49-9d36-65bcfe44c31a" class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-iris bg-iris-50 border border-iris/20 rounded-full px-4 py-2 whitespace-nowrap hover:bg-iris-100 transition-colors" target="_blank" rel="noopener">
              <Icon name="award" size={13} class="text-iris" />
              1st Stripe Certified Architect · cert co-developer
            </a>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-medium text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap">
              <Icon name="shield-check" size={13} class="text-stone-500" />
              ISO 27001 Auditor
            </span>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-medium text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap">
              <Icon name="globe" size={13} class="text-stone-500" />
              AI, Python & JS Community Leader
            </span>
          </div>

          <p class="text-[13px] text-stone-500 leading-relaxed">
            Leading AI, Python, and JavaScript engineering communities internally at DataArt. Run the weekly Global Python Community Session.
          </p>
        </div>
      </section>

      <!-- Projects + Writing -->
      <div class="flex flex-col md:flex-row gap-14 md:gap-20 mb-16">

        <!-- Projects -->
        <section class="md:w-1/2">
          <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-5">Projects</h2>
          <div class="space-y-8">
            <a href="https://github.com/iorlas/iorlas-kay" class="flex items-start gap-4 group" target="_blank" rel="noopener">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-stone-100 flex items-center justify-center mt-0.5">
                <Icon name="brain" size={17} class="text-stone-500" />
              </div>
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors flex items-center gap-1.5">
                  iorlas-kay
                  <Icon name="arrow-up-right" size={12} class="text-stone-500 group-hover:text-iris transition-colors" />
                </p>
                <p class="text-[13px] text-stone-500 leading-relaxed mt-1">Personal knowledge OS — semantic search, entity resolution, structured capture. Built with Claude Code.</p>
              </div>
            </a>

            <a href="https://github.com/iorlas/iorlas-brainstorm" class="flex items-start gap-4 group" target="_blank" rel="noopener">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-stone-100 flex items-center justify-center mt-0.5">
                <Icon name="lightbulb" size={17} class="text-stone-500" />
              </div>
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors flex items-center gap-1.5">
                  iorlas-brainstorm
                  <Icon name="arrow-up-right" size={12} class="text-stone-500 group-hover:text-iris transition-colors" />
                </p>
                <p class="text-[13px] text-stone-500 leading-relaxed mt-1">Decision coaching skill for Claude Code. Detects your reasoning pattern and applies the right technique.</p>
              </div>
            </a>
          </div>
        </section>

        <!-- Publications -->
        <section class="md:w-1/2">
          <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-5">Publications</h2>
          <div class="space-y-8">
            <a href="https://www.dataart.team/articles/guide-to-agentic-ai-autonomous-systems" class="flex items-start gap-4 group" target="_blank" rel="noopener">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-stone-100 flex items-center justify-center mt-0.5">
                <Icon name="pen-line" size={17} class="text-stone-500" />
              </div>
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors">
                  AI Agents: Cutting Through the Noise
                </p>
                <p class="text-[13px] text-stone-500 leading-relaxed mt-1">A practical guide to Agentic AI and autonomous systems.</p>
                <p class="text-[12px] font-mono text-stone-500 mt-1">Oct 2025 · DataArt</p>
              </div>
            </a>

            <a href="https://www.healthcarebusinesstoday.com/superbacteria-the-war-were-going-to-lose-without-ai-and-big-data/" class="flex items-start gap-4 group" target="_blank" rel="noopener">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-stone-100 flex items-center justify-center mt-0.5">
                <Icon name="pen-line" size={17} class="text-stone-500" />
              </div>
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors">
                  Superbacteria: The War We're Going to Lose Without AI and Big Data
                </p>
                <p class="text-[13px] text-stone-500 leading-relaxed mt-1">On AI in the fight against antimicrobial resistance.</p>
                <p class="text-[12px] font-mono text-stone-500 mt-1">2020 · Healthcare Business Today</p>
              </div>
            </a>
          </div>
        </section>

      </div>

      <!-- Trainings -->
      <section class="mb-10">
        <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-4">AI Trainings</h2>
        <a href="/trainings" class="block bg-white border border-stone-200 rounded-lg px-6 py-5 hover:border-iris/30 transition-colors group">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <Icon name="graduation-cap" size={18} class="text-iris" />
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors">Training Programs & Guides</p>
                <p class="text-[12px] text-stone-500 font-mono">Copilot · Claude Code + Go · Claude Code + Next.js · Hackathon</p>
              </div>
            </div>
            <Icon name="arrow-right" size={16} class="text-stone-500 group-hover:text-iris transition-colors" />
          </div>
        </a>
      </section>

      <!-- Travel Guides -->
      <section class="mb-16">
        <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-4">Travel Guides</h2>
        <a href="/travel" class="block bg-white border border-stone-200 rounded-lg px-6 py-5 hover:border-iris/30 transition-colors group">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <Icon name="plane" size={18} class="text-iris" />
              <div>
                <p class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors">City Cheatsheets</p>
                <p class="text-[12px] text-stone-500 font-mono">Istanbul · Alanya · more coming</p>
              </div>
            </div>
            <Icon name="arrow-right" size={16} class="text-stone-500 group-hover:text-iris transition-colors" />
          </div>
        </a>
      </section>

      <!-- Footer -->
      <footer class="border-t border-stone-200/50 pt-10 pb-14 text-center">
        <p class="text-lg font-semibold text-stone-800 mb-1">Building with AI agents? Let's compare notes.</p>
        <p class="text-[14px] text-stone-500 mb-6">Always open to conversations about architecture, agentic patterns, and what's actually working.</p>
        <div class="flex flex-wrap justify-center gap-2.5 mb-6">
          <a href="https://linkedin.com/in/denistomilin-28866686" class="inline-flex items-center gap-1.5 text-[13px] font-mono text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap hover:border-linkedin/30 hover:text-linkedin transition-colors" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://github.com/iorlas" class="inline-flex items-center gap-1.5 text-[13px] font-mono text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap hover:border-stone-400 hover:text-stone-900 transition-colors" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#181717"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            GitHub
          </a>
          <a href="https://x.com/iorlasd" class="inline-flex items-center gap-1.5 text-[13px] font-mono text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap hover:border-stone-400 hover:text-stone-900 transition-colors" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="#000000"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href="https://forms.gle/otSXYCxvH2au6ngm9" class="inline-flex items-center gap-1.5 text-[13px] font-mono text-stone-600 bg-white border border-stone-200 rounded-full px-4 py-2 whitespace-nowrap hover:border-iris/30 hover:text-iris transition-colors" target="_blank" rel="noopener">
            <Icon name="mail" size={14} class="text-iris" />
            Contact
          </a>
        </div>
        <p class="text-[10px] text-stone-500 font-mono">&copy; 2026 Denis Tomilin</p>
      </footer>

    </main>
</Layout>
