---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('trainings');
  return docs.map((doc) => ({
    params: { programSlug: doc.data.programSlug, docSlug: doc.data.docSlug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);
const tocHeadings = headings.filter((h) => h.depth === 2);

// Get all docs in the same program for sidebar navigation
const allDocs = await getCollection('trainings');
const programDocs = allDocs
  .filter((d) => d.data.programSlug === doc.data.programSlug)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${doc.data.title} — ${doc.data.program}`} description={`${doc.data.title} for ${doc.data.program} training program`}>
    <div class="max-w-[1100px] mx-auto px-6 pt-6 sm:pt-10 pb-16">

      <!-- Back link -->
      <a href="/trainings" class="text-sm font-mono text-stone-500 hover:text-iris transition-colors mb-8 inline-block">&larr; All trainings</a>

      <!-- Header -->
      <p class="text-sm font-mono text-iris mb-1">{doc.data.program}</p>
      <h1 class="text-3xl font-bold text-stone-900 mb-10">{doc.data.title}</h1>

      <div class="flex gap-12">

        <!-- Sidebar (desktop) -->
        <nav class="hidden lg:block w-52 shrink-0">
          <div class="sticky top-20 space-y-8">

            <!-- Program docs navigation -->
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-stone-500 mb-3">Program docs</p>
              <ul class="space-y-1.5 border-l border-stone-200">
                {programDocs.map((d) => (
                  <li>
                    <a
                      href={`/trainings/${d.data.programSlug}/${d.data.docSlug}`}
                      class:list={[
                        'block pl-3 text-[13px] border-l-2 -ml-[1px] transition-colors leading-snug py-0.5',
                        d.data.docSlug === doc.data.docSlug
                          ? 'text-iris font-bold border-l-iris'
                          : 'text-stone-500 hover:text-iris hover:border-l-iris border-transparent',
                      ]}
                    >
                      {d.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Table of contents -->
            {tocHeadings.length > 0 && (
              <div>
                <p class="text-[10px] font-mono uppercase tracking-widest text-stone-500 mb-3">On this page</p>
                <ul class="space-y-1.5 border-l border-stone-200">
                  {tocHeadings.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class="block pl-3 text-[13px] text-stone-500 hover:text-iris hover:border-l-iris border-l-2 border-transparent -ml-[1px] transition-colors leading-snug py-0.5"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

          </div>
        </nav>

        <!-- Main content -->
        <main class="min-w-0 max-w-[720px]">

          <!-- Mobile: Program docs navigation -->
          <nav class="lg:hidden mb-8 pb-6 border-b border-stone-200/50">
            <p class="text-[10px] font-mono uppercase tracking-widest text-stone-500 mb-3">Program docs</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1">
              {programDocs.map((d) => (
                <a
                  href={`/trainings/${d.data.programSlug}/${d.data.docSlug}`}
                  class:list={[
                    'text-[13px] transition-colors',
                    d.data.docSlug === doc.data.docSlug
                      ? 'text-iris font-bold'
                      : 'text-stone-500 hover:text-iris',
                  ]}
                >
                  {d.data.title}
                </a>
              ))}
            </div>
          </nav>

          <!-- Mobile: TOC -->
          {tocHeadings.length > 0 && (
            <nav class="lg:hidden mb-10 pb-6 border-b border-stone-200/50">
              <p class="text-[10px] font-mono uppercase tracking-widest text-stone-500 mb-3">On this page</p>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                {tocHeadings.map((h) => (
                  <a
                    href={`#${h.slug}`}
                    class="text-[13px] text-stone-500 hover:text-iris transition-colors"
                  >
                    {h.text}
                  </a>
                ))}
              </div>
            </nav>
          )}

          <!-- Content -->
          <article class="prose prose-stone max-w-none
            prose-headings:font-bold prose-headings:text-stone-900
            prose-h2:text-xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pt-6 prose-h2:border-t prose-h2:border-stone-200/50
            prose-h3:text-base prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-[15px] prose-p:leading-relaxed prose-p:text-stone-600
            prose-li:text-[15px] prose-li:text-stone-600
            prose-a:text-iris prose-a:no-underline hover:prose-a:underline
            prose-strong:text-stone-800
            prose-blockquote:border-l-iris/40 prose-blockquote:bg-iris-50/30 prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-4 prose-blockquote:not-italic
          ">
            <Content />
          </article>

          <!-- GitHub source link -->
          <div class="mt-12 pt-6 border-t border-stone-200/50">
            <a
              href="https://github.com/iorlas/trainings"
              class="inline-flex items-center gap-2 text-sm font-mono text-stone-500 hover:text-iris transition-colors"
              target="_blank"
              rel="noopener"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              View source on GitHub
            </a>
          </div>

        </main>

      </div>
    </div>
</Layout>
