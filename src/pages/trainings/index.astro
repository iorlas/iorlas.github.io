---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const docs = await getCollection('trainings');

// Group by program
const byProgram = new Map<string, typeof docs>();
for (const doc of docs) {
  const group = byProgram.get(doc.data.program) || [];
  group.push(doc);
  byProgram.set(doc.data.program, group);
}

// Separate programs and guides, sort each group
const allGroups = [...byProgram.entries()]
  .map(([program, items]) => ({
    program,
    type: items[0].data.type,
    docs: items.sort((a, b) => a.data.order - b.data.order),
  }));

const programs = allGroups.filter(g => g.type === 'program').sort((a, b) => a.program.localeCompare(b.program));
const guides = allGroups.filter(g => g.type === 'guide').sort((a, b) => a.program.localeCompare(b.program));
const sorted = [...programs, ...guides];
---

<Layout title="AI Trainings — Denis Tomilin" description="Hands-on training programs for AI-assisted development. Open source.">
  <div class="min-h-screen bg-stone-50">

    <!-- Nav -->
    <nav class="max-w-[960px] mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7C5CBA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.341 6.484A10 10 0 0 1 10.266 21.85" />
          <path d="M3.659 17.516A10 10 0 0 1 13.74 2.152" />
          <circle cx="12" cy="12" r="3" />
          <circle cx="19" cy="5" r="2" />
          <circle cx="5" cy="19" r="2" />
        </svg>
        <span class="text-[15px] font-bold text-stone-900">iorlas</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/travel" class="text-[14px] font-bold text-iris hover:text-iris-hover transition-colors">
          ✈ Travel Guides
        </a>
        <a href="/trainings" class="text-[14px] font-bold text-iris hover:text-iris-hover transition-colors">
          🎓 Trainings
        </a>
        <a href="https://forms.gle/otSXYCxvH2au6ngm9" class="text-[13px] text-stone-500 hover:text-iris transition-colors" target="_blank" rel="noopener">Contact</a>
      </div>
    </nav>

    <main class="max-w-[720px] mx-auto px-6 pt-14 sm:pt-20 pb-16">

      <!-- Back link -->
      <a href="/" class="text-sm font-mono text-stone-500 hover:text-iris transition-colors mb-8 inline-block">&larr; Home</a>

      <h1 class="text-3xl font-bold text-stone-900 mb-3">AI Trainings</h1>
      <p class="text-[15px] text-stone-500 leading-relaxed mb-12">
        Hands-on training programs for AI-assisted development. Open source.
      </p>

      {sorted.map(({ program, type, docs }) => (
        <section class="mb-10">
          <h2 class="text-xs font-mono uppercase tracking-widest text-stone-500 mb-4 flex items-center gap-2">
            {program}
            <span class={`text-[10px] font-semibold uppercase tracking-wide rounded-full px-2 py-0.5 ${type === 'program' ? 'bg-iris/10 text-iris' : 'bg-stone-200 text-stone-600'}`}>
              {type}
            </span>
          </h2>
          <div class="space-y-3">
            {docs.map((doc) => (
              <a
                href={`/trainings/${doc.data.programSlug}/${doc.data.docSlug}`}
                class="flex items-center justify-between bg-white border border-stone-200 rounded-lg px-5 py-4 hover:border-iris/30 transition-colors group"
              >
                <span class="text-[15px] font-semibold text-stone-800 group-hover:text-iris transition-colors">
                  {doc.data.title}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- Footer -->
      <div class="mt-8 pt-8 border-t border-stone-200/50 text-center">
        <a href="/" class="text-sm font-mono text-stone-500 hover:text-iris transition-colors">&larr; Home</a>
      </div>
    </main>
  </div>
</Layout>
